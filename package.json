{
  "name": "themadbros",
  "version": "1.0.0",
  "description": "The Mad Bros – static website and creative projects hub.",
  "private": true,
  "scripts": {
    "lint:js": "eslint \"**/*.js\"",
    "lint:html": "htmlhint \"**/*.html\"",
    "lint": "npm run lint:js && npm run lint:html",
    "test": "jest --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "htmlhint": "^1.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "app.js",
      "tmbsocial/assets/js/**/*.js",
      "xtreme-filming/assets/codes/js/**/*.js"
    ]
  }
}
