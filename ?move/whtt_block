<script>
  // 1. Detect the HTTrack User Agent (only works if they don't spoof it)
  if (navigator.userAgent.includes("HTTrack")) {
      window.location.href = "403.html";
  }

  // 2. Kill the page copy if they open the cloned files locally
  if (window.location.protocol === "file:") {
      document.body.innerHTML = "<h1>Access Denied: This content cannot be viewed offline.</h1>";
  }
</script>
